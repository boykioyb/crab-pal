{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@config/*": ["../../packages/shared/src/config/*"],
      "@crabpal/core": ["../../packages/core/src/index.ts"],
      "@crabpal/core/*": ["../../packages/core/src/*"],
      "@crabpal/session-tools-core": ["../../packages/session-tools-core/src/index.ts"],
      "@crabpal/session-tools-core/*": ["../../packages/session-tools-core/src/*"],
      "@crabpal/server-core": ["../../packages/server-core/src/index.ts"],
      "@crabpal/server-core/*": ["../../packages/server-core/src/*"],
      "@crabpal/shared": ["../../packages/shared/src/index.ts"],
      "@crabpal/shared/interceptor": ["../../packages/shared/src/interceptor-common.ts"],
      "@crabpal/shared/*": ["../../packages/shared/src/*"],
      "@crabpal/ui": ["../../packages/ui/src/index.ts"],
      "@crabpal/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
